# ============================================================
#  Synapse AI — Backend Environment Variables
# ============================================================
#  Copy this file into each service directory and fill in the
#  values. Not every service needs every variable — see the
#  "Used by" comments to know which services require it.
#
#  Quick reference of service directories:
#    auth-server, document-server, ai-server, core-server,
#    log-server, admin-server, api-gateway-server
# ============================================================

# ------------------------------
# MongoDB
# ------------------------------
# Used by: ALL services
# Note: log-server uses a separate DB (synapse_logs),
#       admin-server uses a separate DB (synapse_admin),
#       all other services share the main DB (synapse_ai).
MONGODB_URI=mongodb://localhost:27017/synapse_ai

# ------------------------------
# JWT Authentication
# ------------------------------
# Used by: auth-server, admin-server, api-gateway-server
# Note: Must be the SAME value across all three services so
#       the gateway can verify tokens issued by either auth or admin.
JWT_SECRET=

# ------------------------------
# S2S (Service-to-Service) Authentication
# ------------------------------
# Used by: ALL services
# Note: Must be the SAME value across every service.
#       The gateway injects this as x-internal-key; downstream
#       services validate it via the s2sGuard middleware.
S2S_SECRET=

# ------------------------------
# Redis (Azure Cache for Redis)
# ------------------------------
# Used by: document-server, api-gateway-server
# document-server uses Redis for Bloom filter deduplication.
# api-gateway-server uses Redis for rate limiting + Socket.IO adapter.
REDIS_HOST=
REDIS_PORT=6380
REDIS_PASSWORD=

# ------------------------------
# Azure Service Bus
# ------------------------------
# Used by: auth-server, document-server, ai-server, core-server
# Provides the pub/sub messaging backbone (topics & subscriptions).
AZURE_SERVICE_BUS_CONNECTION_STRING=

# ------------------------------
# Azure OpenAI
# ------------------------------
# Used by: ai-server
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_API_VERSION=2024-02-01

# ------------------------------
# Azure AI Search (Vector Storage)
# ------------------------------
# Used by: ai-server
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=synapse-ai-index

